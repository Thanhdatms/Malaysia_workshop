# Copy this file to ".env" (same directory as docker-compose.yml) on the
# EC2 server and fill in real values. This file is read by docker-compose
# for variable substitution - it never gets baked into the image.

# Postgres (self-hosted in the "db" container, not RDS)
POSTGRES_USER=workshop
POSTGRES_PASSWORD=password
POSTGRES_DB=workshop

# Facilitator dashboard token (GET /admin) - pick something non-guessable.
ADMIN_TOKEN=bossard-admin

# Optional: enables the in-app "Ask AI" chat widget (see CLAUDE.md section 9.1).
# Leave blank to disable it (endpoint returns 503, widget shows an error).
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat