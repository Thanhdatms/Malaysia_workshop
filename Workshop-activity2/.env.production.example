# Copy this file to ".env" (same directory as docker-compose.yml) on the
# EC2 server and fill in real values. This file is read by docker-compose
# for variable substitution - it never gets baked into the image.

# Postgres (self-hosted in the "db" container, not RDS)
POSTGRES_USER=workshop
POSTGRES_PASSWORD=password
POSTGRES_DB=workshop

# Facilitator dashboard token (GET /admin) - pick something non-guessable.
ADMIN_TOKEN=bossard-admin

# Domain Caddy will request an HTTPS cert for (see docker-compose.yml's
# "caddy" service). No domain of your own? Use sslip.io, which resolves
# straight to your instance's public IP - just swap in your IP with dots
# replaced by dashes, e.g. 54.153.195.100 -> 54-153-195-100.sslip.io
SITE_DOMAIN=54-153-195-100.sslip.io

# Required for every AI feature in Step 3/4 (Organize Steps, Evaluate
# Proposal, Generate/Edit Workflow, Analysis Summary, ChatWidget). Leave
# blank to run without AI - Steps 1-2, manual Step 3 editing, and admin
# still work fine.
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
